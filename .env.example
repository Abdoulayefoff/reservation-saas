# .env.example – Template de configuration
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env

# GÉNÉRAL
APP_ENV=dev

# JWT – Partagé entre Auth Service et API Gateway
JWT_SECRET=change_me_with_a_very_long_random_secret_key_at_least_64_chars
JWT_TTL=3600
JWT_REFRESH_TTL=604800

# BASE DE DONNÉES – Auth Service
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_secure_password_change_me
AUTH_DATABASE_URL=postgresql://auth_user:auth_secure_password_change_me@auth-db:5432/auth_db

# BASE DE DONNÉES – User Service
USER_DB_HOST=user-db
USER_DB_PORT=5432
USER_DB_NAME=user_db
USER_DB_USER=user_user
USER_DB_PASSWORD=user_secure_password_change_me
USER_DATABASE_URL=postgresql://user_user:user_secure_password_change_me@user-db:5432/user_db

# BASE DE DONNÉES – Event Service
EVENT_DB_HOST=event-db
EVENT_DB_PORT=5432
EVENT_DB_NAME=event_db
EVENT_DB_USER=event_user
EVENT_DB_PASSWORD=event_secure_password_change_me
EVENT_DATABASE_URL=postgresql://event_user:event_secure_password_change_me@event-db:5432/event_db

# BASE DE DONNÉES – Ticket Service
TICKET_DB_HOST=ticket-db
TICKET_DB_PORT=5432
TICKET_DB_NAME=ticket_db
TICKET_DB_USER=ticket_user
TICKET_DB_PASSWORD=ticket_secure_password_change_me
TICKET_DATABASE_URL=postgresql://ticket_user:ticket_secure_password_change_me@ticket-db:5432/ticket_db

# RABBITMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_secure_password_change_me
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://rabbit_user:rabbit_secure_password_change_me@rabbitmq:5672/

# URLs INTERNES DES SERVICES (réseau Docker interne)
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
EVENT_SERVICE_URL=http://event-service:8003
TICKET_SERVICE_URL=http://ticket-service:8004

# PORTS D'ÉCOUTE
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
EVENT_SERVICE_PORT=8003
TICKET_SERVICE_PORT=8004
NOTIFICATION_SERVICE_PORT=8005
API_GATEWAY_PORT=8000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost